# Скопируйте этот файл в avito.env и заполните значения.
# API выключен, пока AVITO_ENABLE_API не равен 1.
AVITO_ENABLE_API=0

AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

AVITO_ACCOUNT_ID=
AVITO_CAMPAIGN_ID=
AVITO_CAMPAIGN_NAME=Дружеский

AVITO_TOKEN_URL=https://api.avito.ru/token
AVITO_BASE_URL=https://api.avito.ru

# По умолчанию используется:
# POST /ads/v1/account/{account_id}/campaigns/{campaign_id}/stats
# Скрипт делает один запрос к статистике за период и сохраняет результат в data/avito/druzheskiy.json.
AVITO_STATS_METHOD=POST

# Необязательно: переопределить endpoint и тело запроса.
AVITO_STATS_PATH_TEMPLATE=
AVITO_STATS_BODY_JSON=

AVITO_GROUP_BY=day
AVITO_LOOKBACK_DAYS=90

# Необязательно: зафиксировать период вручную.
# AVITO_DATE_FROM=2026-06-01
# AVITO_DATE_TO=2026-06-09
