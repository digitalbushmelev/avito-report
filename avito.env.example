# Скопируйте этот файл в avito.env и заполните значения.
# API выключен, пока AVITO_ENABLE_API не равен 1.
AVITO_ENABLE_API=0

AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

AVITO_ACCOUNT_ID=
AVITO_CAMPAIGN_ID=
AVITO_CAMPAIGN_NAME=Дружеский

# Несколько кампаний можно задать явно через env или через avito_campaigns.json.
# avito_campaigns.json используется как fallback, если endpoint списка кампаний
# недоступен для ключа.
# AVITO_CAMPAIGN_IDS=843568278,123456789
# AVITO_CAMPAIGN_NAMES=Дружеский,Новая кампания
# AVITO_CAMPAIGN_SLUGS=druzheskiy,new-campaign
# AVITO_CAMPAIGN_REGISTRY_FILE=avito_campaigns.json

# По умолчанию скрипт пытается получить список кампаний аккаунта:
# GET /ads/v1/account/{account_id}/campaigns
# Если Avito вернет ошибку, используется явный список выше или AVITO_CAMPAIGN_ID.
AVITO_AUTO_DISCOVER_CAMPAIGNS=1
AVITO_WRITE_DISCOVERED_CAMPAIGNS=1
AVITO_CAMPAIGN_LIST_PATH_TEMPLATE=

AVITO_TOKEN_URL=https://api.avito.ru/token
AVITO_BASE_URL=https://api.avito.ru

# По умолчанию используется:
# POST /ads/v1/account/{account_id}/campaigns/{campaign_id}/stats
# Скрипт делает запрос статистики по каждой кампании и сохраняет результат в data/avito/*.json.
AVITO_STATS_METHOD=POST

# Необязательно: переопределить endpoint и тело запроса.
AVITO_STATS_PATH_TEMPLATE=
AVITO_STATS_BODY_JSON=

AVITO_GROUP_BY=day
AVITO_LOOKBACK_DAYS=90

# Необязательно: зафиксировать период вручную.
# AVITO_DATE_FROM=2026-06-01
# AVITO_DATE_TO=2026-06-09
